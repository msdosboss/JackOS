class Screen{
    static bool color;

    function void clearScreen(){
        var int currentWordPointer;
        // This is the starting address for the screen
        let currentWordPointer = 16384;
        // 24575 is the last pixel 
        while(currentWordPointer < 24576){
            let currentWordPointer[0] = 0;
            let currentWordPointer = currentWordPointer + 1;
        }
        return;
    }

    function void setColor(bool b){
        let color = b;
        return;
    }

    function int cordToMemLoc(int x, int y){
        return 16384 + ((x / 16) + (32 * y));
    }

    function void drawPixel(int x, int y){
        var int pixelWordPointer, bitVal, n;
        if((y > 255) | (x > 511)){
            return;
        }

        let pixelWordPointer = Screen.cordToMemLoc(x, y);
        let n = Math.mod(x, 16);
        let bitVal = Math.bitshiftLeft(1, n);
        if(color = true){
            let pixelWordPointer[0] = pixelWordPointer[0] | bitVal;
        }
        else{
            let bitVal = ~bitVal;
            let pixelWordPointer[0] = pixelWordPointer[0] & bitVal;
        }
        return;
    }

/*    function void drawLine(int x1, int y1, int x2, int y2){
        var int dx, dy, a, b;
        let dx = x2 - x1;
        let dy = y2 - y1;
        let a = 0;
        let b = 0;

        while((a < dx) & (b < dy)){
            do Screen.drawPixel(x1 + a, y1 + b);
            if((b / a) > (dy / dx)){
                // Move Right
                let a = a + 1;
            }
            else{
                // Move Up
                let b = b + 1;
            }
        }

        return;
    }
*/

    function void drawLine(int x1, int x2, int y1){
        if(x1 < 0){
            return;
        }
        if(x2 > 511){
            return;
        }

        while(x1 < x2){
            do Screen.drawPixel(x1, y1);
            let x1 = x1 + 1;
        }

        return;
    }
}
